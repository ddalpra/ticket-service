# ─────────────────────────────────────────────────────────────────────────────
#  .env.example — Copia in .env e personalizza
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL
DATABASE_URL=postgres://ticket:ticket_secret@localhost:5432/ticketdb?sslmode=disable

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=ticket
KEYCLOAK_CLIENT_ID=ticket-service
KEYCLOAK_CLIENT_SECRET=ticket-service-secret

# App
SERVER_PORT=3000
GIN_MODE=debug          # debug | release | test

# ── Mail Worker ───────────────────────────────────────────────────────────────
# Percorso del file credentials.json scaricato da Google Cloud Console
GMAIL_CREDENTIALS_PATH=credentials.json
# Intervallo di polling (es. 1m, 5m, 15m)
MAIL_POLL_INTERVAL=5m
# Numero massimo di email elaborate per ciclo
MAIL_MAX_PER_CYCLE=20
# UUID del centro servizi a cui assegnare i ticket da email
# Se vuoto usa il primo centro servizi attivo
MAIL_DEFAULT_SC_ID=
